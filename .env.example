# Telegram
BOT_TOKEN=your_telegram_bot_token

# MEXC (default keys for single-user mode, can also be set per-user via /start)
# These are optional — user provides keys via Telegram chat

# Security
ENCRYPTION_KEY=generate_with_python_-c_"from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# Database
DB_PATH=data/bot.db

# Logging
LOG_LEVEL=INFO

# Admin (Telegram user ID who can use the bot)
ADMIN_USER_ID=0
